root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,groovy,gradle}]
indent_style = space
indent_size = 4
continuation_indent_size = 4

[*.md]
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab

[*.bat]
end_of_line = crlf
